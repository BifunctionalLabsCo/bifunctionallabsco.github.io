---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="bifunctional — Greetings Wanderer">
  <Fragment slot="head">
    <style is:inline>
    :root{
      /* Approx palette based on the PDF */
       --teal-400:#40ffb5;
      --teal-600: #00634d;
      --teal-800: #032b22;
      --cream: #efede7;
      --pink: #ffafda;
     
      --white:#ffffff;
      --muted:#6e6e6e;

      --max: 1120px;
      --gutter: 28px;

      --serif: "Fraunces", serif;
      --caps: "Cormorant Garamond", serif;
      --sans: "Montserrat", system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, sans-serif;

      --shadow: 0 18px 40px rgba(0,0,0,.18);
      --shadow-soft: 0 10px 30px rgba(0,0,0,.12);
      --radius: 10px;
      --radius-lg: 14px;
    }

    *{box-sizing:border-box}
    html{height:100%;overscroll-behavior:none}
    body{height:100%;
      margin:0;
      color:var(--teal-800);
      background:var(--cream);
      font-family:var(--sans);
      line-height:1.45;
    }

    /* Helpers */
    .wrap{
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 var(--gutter);
    }
    .section{
      padding: 54px 0;
    }
    .two-col{
      display:grid;
      grid-template-columns: 1.05fr 1.35fr;
      gap: 34px;
      align-items:center;
    }
    .two-col.image-left{
      grid-template-columns: 1.35fr 1.05fr;
    }
    .media{
      width:100%;
      border-radius: var(--radius-lg);
      overflow:hidden;
      box-shadow: var(--shadow-soft);
      background:#ddd;
      aspect-ratio: 16 / 9;
      position:relative;
    }
    .media img{
      width:100%;
      height:100%;
      object-fit:cover;
      display:block;
    }

    /* Circular portrait cutout */
    .portrait-circle{
      border-radius: 50%;
      aspect-ratio: 1 / 1;
      box-shadow: 0 18px 50px rgba(0,0,0,.35);
      max-width: 85%;
      justify-self: center;
    }
    .portrait-circle img{
      transform: scale(1.15);
    }

    /* HERO */
    .hero{
      min-height: 560px;
      background:
        linear-gradient(to bottom, rgba(0,0,0,.35), rgba(0,0,0,.45)),
        url("assets/hero.png") center/cover no-repeat;
      display:flex;
      align-items:center;
      position:relative;
      overflow:hidden;
    }

    /* optional subtle corner mark (like a minimalist sigil/logo) */
    .hero::after{
      content:"";
      position:absolute;
      top: 28px;
      left: 50%;
      transform: translateX(-50%);
      width: 72px;
      height: 72px;
      background: url("assets/logo.png") center/contain no-repeat;
      filter: drop-shadow(0 10px 20px rgba(0,0,0,.35));
      pointer-events:none;
    }

    .hero-inner{
      width:100%;
      text-align:center;
      color:var(--white);
      padding: 96px 0 58px;
    }

    .hero-kicker{
      font-family: var(--caps);
      text-transform: uppercase;
      font-size: 24px;
      opacity:.9;
      margin: 0 0 18px;
    }

    .hero-we-are{
      font-family: var(--serif);
      font-size: clamp(60px, 4.5vw, 80px);
      margin: 0 0 4px;
      letter-spacing: .04em;
      color: var(--pink);
      font-style:light;
    }

    .hero-title{
      font-family: "Poppins", sans-serif;
      font-weight: 600;
      font-size: clamp(80px, 7vw, 88px);
      margin: 0 0 8px;
      letter-spacing: .02em;
      text-transform: lowercase;
      text-shadow: 0 10px 24px rgba(0,0,0,.35);
    }

    .hero-subtitle{
      max-width: 720px;
      margin: 0 auto 20px;
      font-family: var(--caps);
      font-size: 24px;
      color:var(--teal-400);
      opacity:.92;
    }

    .hero-flag{
      display:inline-block;
      margin-left: 6px;
      filter: drop-shadow(0 8px 18px rgba(0,0,0,.35));
    }

    .hero-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 12px 22px;
      font-family: var(--caps);
      letter-spacing: .18em;
      text-transform: uppercase;
      font-size: 16px;
      color: var(--teal-400);
      border: 2px solid rgba(64,255,181,.35);
      border-radius: 10px;
      text-decoration:none;
      backdrop-filter: blur(6px);
      background: rgba(64,255,181,.08);
      transition: transform .18s ease, background .18s ease;
      margin-top: 10px;
    }
    .hero-btn:hover{
      transform: translateY(-1px);
      background: rgba(64,255,181,.15);
    }

    /* SECTION: Zubin */
    .panel-cream{
      background: var(--cream);
    }
    .heading-small{
      font-family: var(--serif);
      color: var(--teal-600);
      font-weight: 500;
      font-style: italic;
      font-size: 42px;
      margin: 0 0 15px;
      letter-spacing: .02em;
      line-height: 1.05;
    }
    .subcaps{
      font-family: "Montserrat", sans-serif;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-size: 18px;
      font-weight: 500;
      margin: 0;
      opacity:.85;
    }
    .subcaps + .subcaps{ margin-top: 6px; }

    .body-copy{
      font-family: var(--caps);
      color: var(--teal-800);
      font-size: 20px;
      margin: 14px 0 0;
      max-width: 52ch;
      font-weight: 600;
    }

    /* SECTION: Saumya dark panel */
    .panel-dark{
      background: var(--teal-800);
      color: var(--cream);
    }
    .panel-dark .heading-small{
      color: var(--cream);
    }
    .panel-dark .subcaps{
      color: var(--cream);
      opacity: .92;
    }
    .panel-dark .body-copy{
      color: var(--cream);
    }

    /* STUDIO SERVICES */
    .services{
      background: var(--cream);
    }
    .services-header{
      text-align:center;
      margin: 0 auto 28px;
      max-width: 720px;
    }
    .services-title{
      font-family: var(--serif);
      font-size: 42px;
      font-weight: 600;
      font-style: italic;
      margin: 0 0 10px;
      color: var(--teal-600);
      letter-spacing: .01em;
    }
    .services-subtitle{
      font-family: var(--sans);
      font-size: 14px;
      margin: 0;
      color: var(--teal-800);
      opacity: .8;
    }
    .services-grid{
      display:grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }
    .service-card{
      border: 2px solid var(--teal-600);
      border-radius: 6px;
      padding: 26px 24px 28px;
      background: var(--cream-2);
      color: var(--teal-800);
      box-shadow: 0 10px 24px rgba(0,0,0,.08);
    }
    .service-name{
      font-family: var(--serif);
      font-size: 22px;
      font-weight: 600;
      text-align:center;
      margin: 0 0 12px;
      letter-spacing: .01em;
      color: var(--teal-600);
    }
    .service-meta{
      font-family: "Montserrat", sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .12em;
      text-transform: uppercase;
      text-align:center;
      margin: 0 0 16px;
    }
    .service-copy{
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.55;
      text-align:center;
      margin: 0 0 14px;
      color: var(--teal-800);
    }
    .service-copy + .service-copy{ margin-top: 8px; }
    .service-price{
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 600;
      text-align:center;
      margin: 18px 0 0;
    }
    .services-cta{
      text-align:center;
      margin-top: 26px;
    }
    .service-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap: 8px;
      padding: 14px 28px;
      background: var(--teal-600);
      color: var(--cream);
      font-family: "Montserrat", sans-serif;
      font-size: 16px;
      font-weight: 700;
      letter-spacing: .1em;
      text-transform: uppercase;
      border: 2px solid var(--teal-600);
      border-radius: 10px;
      text-decoration:none;
      transition: transform .15s ease, background .15s ease;
    }
    .service-btn:hover{
      transform: translateY(-1px);
      background: #004f3e;
    }
    .blog-link{ display:inline-flex; }

    .section-cta{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 10px 22px;
      font-family: var(--caps);
      letter-spacing: .14em;
      text-transform: uppercase;
      font-size: 15px;
      border-radius: 8px;
      text-decoration:none;
      transition: transform .18s ease, background .18s ease, box-shadow .18s ease;
      margin-top: 18px;
    }
    .section-cta:hover{
      transform: translateY(-1px);
    }
    .section-cta-cream{
      color: var(--teal-600);
      border: 2px solid rgba(0,99,77,.35);
      background: rgba(0,99,77,.08);
    }
    .section-cta-cream:hover{
      background: rgba(0,99,77,.15);
    }
    .section-cta-dark{
      color: var(--teal-400);
      border: 2px solid rgba(64,255,181,.35);
      background: rgba(64,255,181,.08);
    }
    .section-cta-dark:hover{
      background: rgba(64,255,181,.15);
    }

    .title-script{
      font-family: var(--serif);
      color: var(--teal-400);
      font-size: 42px;
      font-weight: 600;
      line-height: 1.05;
      margin: 0 0 15px;
      letter-spacing: .02em;
      font-style: italic;
    }

    /* TRAVEL + EXPEDITIONS */
    .panel-pink{
      background: var(--pink);
      color: var(--teal-800);
    }
    .exp-title{
      text-align:center;
      font-family: var(--serif);
      font-style: italic;
      font-weight: 600;
      font-size: 42px;
      margin: 0 0 8px;
      color: var(--teal-800);
    }
    .travel-title{
      font-family: "Montserrat", sans-serif;
      font-weight:500;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-size: 18px;
      text-align:center;
      margin: 0 0 22px;
      color: var(--teal-800);
    }
    .travel-hero{
      max-width: 560px;
      margin: 0 auto 10px;
      text-align:center;
    }
    .travel-hero .media{
      aspect-ratio: 1 / 1;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-soft);
    }
    .caption{
      font-family: var(--serif);
      font-size: 14px;
      color: var(--teal-800);
      margin: 12px auto 0;
      max-width: 74ch;
      font-style: italic;
      text-align:center;
      line-height: 1.45;
    }
    .exp-sub{
      text-align:center;
      font-family: var(--caps);
      font-size: 16px;
      font-weight: 600;
      color: var(--teal-800);
      margin: 24px 0 24px;
      letter-spacing: .08em;
    }
    .cards{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }
    .card{
      background: rgba(255,255,255,.0);
      border-radius: 12px;
      overflow:hidden;
      box-shadow: none;
    }
    .card .thumb{
      border-radius: 12px;
      overflow:hidden;
      box-shadow: var(--shadow-soft);
      aspect-ratio: 4 / 3;
      background:#ddd;
    }
    .card .thumb img{
      width:100%;
      height:100%;
      object-fit: cover;
      display:block;
    }
    .card .meta{
      text-align:center;
      margin-top: 8px;
    }
    .card .meta .kicker{
      font-family: "Montserrat", sans-serif;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-size: 12px;
      color: var(--teal-800);
      font-weight: 600;
      margin-bottom: 4px;
    }
    .card .meta .place{
      font-family: var(--serif);
      font-size: 18px;
      color: var(--teal-800);
      font-weight: 600;
      font-style: italic;
    }

    /* FOOTER */
    .footer{
      background: var(--teal-800);
      color: var(--cream);
      padding: 54px 0 64px;
      position:relative;
      overflow:hidden;
    }
    .footer .wrap{
      position:relative;
      padding-right: 160px;
    }
    .footer h3{
      margin: 0 0 18px;
      text-align:center;
      font-family: "Montserrat", sans-serif;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-size: 24px;
      font-weight: 600;
      color: var(--teal-400);
    }
    .footer .footer-title{
      text-align:center;
      font-family: var(--serif);
      font-size: 24px;
      margin: 0 0 20px;
    }

    .footer p{
      margin: 0 auto 14px;
      text-align:center;
      font-size: 18px;
      font-weight: 400;
      max-width: 76ch;
      color: var(--cream);
    }
    .socials{
      display:flex;
      justify-content:center;
      gap: 14px;
      margin-top: 18px;
    }
    .icon-btn{
      width: 52px;
      height: 52px;
      border-radius: 999px;
      display:grid;
      place-items:center;
      border: 1.5px solid rgba(64,255,181,.25);
      background: rgba(64,255,181,.08);
      transition: transform .18s ease, background .18s ease;
      text-decoration:none;
    }
    .icon-btn:hover{
      transform: translateY(-2px);
      background: rgba(64,255,181,.16);
    }
    .icon-btn svg{
      width: 22px;
      height: 22px;
      fill: var(--teal-400);
    }

    /* right-side vertical branding */
    .watermark{
      display:none;
    }
    .footer-branding{
     position: absolute;
  top: 2%;
  right: 50px;

  /* MUST have a real box for background to render */
  width: 420px;     /* your horizontal image width (tweak) */
  height: 90px;     /* your horizontal image height (tweak) */

  transform: translateY(-50%) rotate(-90deg);
  transform-origin: right center;

  background: url("assets/footer-branding.png") center / contain no-repeat;
  opacity: .25;
  pointer-events: none;
  z-index: 2;
    }

    /* Responsive */
    @media (max-width: 980px){
      .two-col{ grid-template-columns: 1fr; }
      .body-copy{ max-width: unset; }
      .cards{ grid-template-columns: 1fr; }
      .hero{ min-height: 520px; }
      .watermark{ display:none; }
      .footer-branding{ display:none; }
      .services-grid{ grid-template-columns: 1fr; }
      .service-card{ max-width: 520px; margin: 0 auto; }
      .footer .wrap{ padding-right: var(--gutter); }
    }

    @media (max-width: 520px){
      :root{ --gutter: 18px; }
      .section{ padding: 42px 0; }
      .hero-inner{ padding: 56px 0 52px; }
      .hero-kicker{ letter-spacing: .2em; }
      .hero-btn{ padding: 11px 18px; }
      .title-script{ font-size: 36px; }
      .exp-title{ font-size: 36px; }
      .service-name{ font-size: 20px; }
      .service-meta{ font-size: 11px; }
      .service-copy{ font-size: 13px; }
      .service-btn{ width: 100%; max-width: 320px; }
    }
    </style>
  </Fragment>

  <!-- HERO -->
  <header class="hero">
    <div class="wrap hero-inner">
      <p class="hero-kicker">G R E E T I N G S&nbsp;&nbsp;W A N D E R E R</p>
      <p class="hero-we-are">We are</p>
      <h1 class="hero-title">bifunctional</h1>
      <p class="hero-subtitle">
        A community-minded, hobby software<br>
        studio based out of Berlin <span class="hero-flag">🇩🇪</span>
      </p>
      <a class="hero-btn" href="#learn-more">Learn More</a>
    </div>
  </header>

  <!-- ZUBIN -->
  <section id="learn-more" class="section panel-cream">
    <div class="wrap">
      <div class="two-col">
        <div>
          <h2 class="heading-small">Hey. I'm Zubin</h2>
          <p class="subcaps">DATA PRACTITIONER,</p>
          <p class="subcaps">ASPIRING TECHNOLOGIST</p>
          <p class="subcaps">AND ALL-ROUND NERD</p>

          <p class="body-copy">
            Focused on my start-up in Berlin but still manage to blog about
            career, code, data, and design. All my links are collected on the page below.
          </p>
          <a class="section-cta section-cta-cream" href="#contact">Visit My Blog</a>
        </div>

        <div class="media" aria-label="Zubin photo">
          <img src="assets/images/00z.jpg" alt="Zubin — placeholder image" />
        </div>
      </div>
    </div>
  </section>

  <!-- SAUMYA / DESIGN WITH PURPOSE -->
  <section class="section panel-dark">
    <div class="wrap">
      <div class="two-col">
        <div>
          <h2 class="title-script">Design with Purpose</h2>
          <p class="subcaps">EMPATHY IN EVERY PIXEL</p>

          <p class="body-copy">
            Saumya crafts user experiences that blend functionality with aesthetics.
            With a strong background in UX design, she thrives on solving complex problems
            with a user-centric approach. Passionate about creating meaningful connections,
            Saum's work is rooted in empathy and innovation, always aiming to make a lasting impact.
          </p>
          <a class="section-cta section-cta-dark" href="#services">View My Work</a>
        </div>

        <div class="media portrait-circle" aria-label="Saumya photo">
          <img src="assets/images/01s.jpg" alt="Saumya — placeholder image" />
        </div>
      </div>
    </div>
  </section>

  <!-- STUDIO SERVICES -->
  <section id="services" class="section services">
    <div class="wrap">
      <div class="services-header">
        <h2 class="services-title">Our Studio Services</h2>
        <p class="services-subtitle">We are currently offering two packaged solutions</p>
      </div>

      <div class="services-grid">
        <article class="service-card">
          <h3 class="service-name">Venture Kick-Starter Package</h3>
          <p class="service-meta">1 week | 10 hours</p>
          <p class="service-copy">For founders ready to launch a new product or business with clarity and momentum.</p>
          <p class="service-copy">
            Over one focused week, we design and implement a tailored launch foundation. This includes a website and
            the configuration of selected software tools aligned to your specific priorities. Depending on your needs,
            the sprint may focus on e-commerce or shop integrations, automation workflows, customer and market intelligence
            systems, or lead generation infrastructure — with scope defined collaboratively to ensure meaningful execution
            within the timeframe.
          </p>
          <p class="service-copy">The outcome is a strategic and operational base that gets you live, structured, and ready to grow.</p>
          <p class="service-price">€800</p>
        </article>

        <article class="service-card">
          <h3 class="service-name">Brand Design Package</h3>
          <p class="service-meta">1 week | 4 hrs</p>
          <p class="service-copy">For founders seeking to establish a clear and cohesive brand foundation.</p>
          <p class="service-copy">
            Over one focused week, we collaborate to define and design your core identity system. This results in a concise
            brand book that includes your primary logo suite, essential visual assets, and digital style guidelines tailored
            to your direction and ambitions.
          </p>
          <p class="service-copy">The outcome is a strategic identity framework designed to evolve alongside your business.</p>
          <p class="service-price">€400</p>
        </article>
      </div>

      <div class="services-cta">
        <a class="service-btn" href="#contact">Book a Call</a>
      </div>
    </div>
  </section>

  <!-- EXPEDITIONS + TRAVEL -->
  <section id="expeditions" class="section panel-pink">
    <div class="wrap">
      <h2 class="exp-title">Expeditions</h2>
      <p class="travel-title">LIKE EVERY OTHER BORING TECH DUO WE ALSO BLOG ABOUT TRAVEL</p>

      <div class="travel-hero">
        <div class="media">
          <img src="assets/images/02f.jpg" alt="Family travel photo — placeholder image" />
        </div>
        <p class="caption">
          A family-postcard selfie with the backdrop of the Marble Mountains, found in central Vietnam,
          a short excursion from Da Nang or Hoi An.
        </p>
      </div>

      <div class="services-cta">
        <a class="service-btn blog-link" href="expeditions/">To Expeditions</a>
      </div>
    </div>
  </section>

  <!-- FOOTER / CROSS-COLLABORATION -->
  <footer id="contact" class="footer">
    <div class="wrap">
      <h3>CROSS-COLLABORATION</h3>
      <div class="footer-title">We are a community-minded, hobby software<br>studio based out of Berlin.</div>

      <p class="body-copy">
        We are most passionate about projects at the intersection of design and emergent technologies
        (think AI &amp; ML).
      </p>
      <p class="body-copy">
        Get in touch if you would like to have a coffee chat about the same.
      </p>
      <p class="body-copy">You can find us on a couple different socials:</p>

      <div class="socials" aria-label="social links">
        <a class="icon-btn" href="#" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a class="icon-btn" href="#" aria-label="X (Twitter)">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
