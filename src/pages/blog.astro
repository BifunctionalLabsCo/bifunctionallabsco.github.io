---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="bifunctional — Expeditions">
  <Fragment slot="head">
    <style is:inline>
    :root{
      --teal-400:#40ffb5;
      --teal-600: #00634d;
      --teal-800: #032b22;
      --cream: #eeeae3;
      --cream-2:#f3efe9;
      --pink: #f6b4d6;
      --white:#ffffff;
      --max: 1120px;
      --gutter: 28px;
      --serif: "Fraunces", serif;
      --caps: "Cormorant Garamond", serif;
      --sans: Inter, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, sans-serif;
      --shadow-soft: 0 10px 30px rgba(0,0,0,.12);
      --radius-lg: 14px;
    }
    *{box-sizing:border-box;}
    body{
      margin:0;
      background: var(--pink);
      color: var(--teal-800);
      font-family: var(--sans);
    }
    .wrap{
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 var(--gutter);
    }
    .section{ padding: 54px 0 64px; }

    .exp-title{
      text-align:center;
      font-family: var(--serif);
      font-style: italic;
      font-weight: 600;
      font-size: 42px;
      margin: 0 0 8px;
      color: var(--teal-800);
    }
    .travel-title{
      font-family: "Montserrat", sans-serif;
      font-weight:600;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-size: 16px;
      text-align:center;
      margin: 0 0 22px;
      color: var(--teal-800);
    }
    .travel-hero{
      max-width: 560px;
      margin: 0 auto 10px;
      text-align:center;
    }
    .travel-hero .media{
      width:100%;
      border-radius: var(--radius-lg);
      overflow:hidden;
      aspect-ratio: 1 / 1;
      box-shadow: var(--shadow-soft);
      background:#ddd;
    }
    .travel-hero img{ width:100%; height:100%; object-fit:cover; display:block; }
    .caption{
      font-family: var(--serif);
      font-size: 14px;
      color: var(--teal-800);
      margin: 12px auto 0;
      max-width: 74ch;
      font-style: italic;
      text-align:center;
      line-height: 1.45;
    }
    .exp-sub{
      text-align:center;
      font-family: var(--caps);
      font-size: 16px;
      font-weight: 600;
      color: var(--teal-800);
      margin: 24px 0 24px;
      letter-spacing: .08em;
    }
    .cards{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }
    .card{
      background: rgba(255,255,255,.0);
      border-radius: 12px;
      overflow:hidden;
      box-shadow: none;
    }
    .card .thumb{
      border-radius: 12px;
      overflow:hidden;
      box-shadow: var(--shadow-soft);
      aspect-ratio: 4 / 3;
      background:#ddd;
    }
    .card .thumb img{
      width:100%;
      height:100%;
      object-fit: cover;
      display:block;
    }
    .card .meta{
      text-align:center;
      margin-top: 8px;
    }
    .card .meta .kicker{
      font-family: "Montserrat", sans-serif;
      letter-spacing: .18em;
      text-transform: uppercase;
      font-size: 12px;
      color: var(--teal-800);
      font-weight: 600;
      margin-bottom: 4px;
    }
    .card .meta .place{
      font-family: var(--serif);
      font-size: 18px;
      color: var(--teal-800);
      font-weight: 600;
      font-style: italic;
    }
    .back-link{
      display:inline-block;
      margin-top: 22px;
      font-family: "Montserrat", sans-serif;
      font-weight: 600;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--teal-800);
      text-decoration:none;
      border-bottom: 1px solid rgba(0,0,0,.25);
      padding-bottom: 3px;
    }
    @media (max-width: 780px){
      .cards{ grid-template-columns: 1fr; }
      .travel-hero{ max-width: 100%; }
    }
    </style>
  </Fragment>

  <section class="section">
    <div class="wrap">
      <h1 class="exp-title">Expeditions</h1>
      <p class="travel-title">LIKE EVERY OTHER BORING TECH DUO WE ALSO BLOG ABOUT TRAVEL</p>

      <div class="travel-hero">
        <div class="media">
          <img src="assets/images/02f.jpg" alt="Family travel photo — placeholder image" />
        </div>
        <p class="caption">
          A family-postcard selfie with the backdrop of the Marble Mountains, found in central Vietnam,
          a short excursion from Da Nang or Hoi An.
        </p>
      </div>

      <p class="exp-sub">Here's a small preview a preview of some of our more recent trips and expeditions</p>

      <div class="cards">
        <article class="card">
          <div class="thumb">
            <img src="images/expeditions/alps.jpg" alt="Into the Alps — placeholder image" />
          </div>
          <div class="meta">
            <div class="kicker">INTO THE ALPS | PART 1</div>
            <div class="place">Salzburg</div>
          </div>
        </article>

        <article class="card">
          <div class="thumb">
            <img src="images/expeditions/verona.jpg" alt="Of Brawls & Bridges — placeholder image" />
          </div>
          <div class="meta">
            <div class="kicker">OF BRAWLS &amp; BRIDGES</div>
            <div class="place">Verona</div>
          </div>
        </article>

        <article class="card">
          <div class="thumb">
            <img src="images/expeditions/thailand.jpg" alt="Glimpses of Thailand — placeholder image" />
          </div>
          <div class="meta">
            <div class="kicker">GLIMPSES OF THAILAND | 2018</div>
            <div class="place">Andaman Sands</div>
          </div>
        </article>
      </div>

      <a class="back-link" href="index.html">← Back to home</a>
    </div>
  </section>
</BaseLayout>
